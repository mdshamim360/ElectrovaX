rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "mdshamimbdyt0@gmail.com" ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true)
      );
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Product Validation ---
    function isValidProduct(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 200
        && data.price is number && data.price >= 0
        && data.image is string && data.image.size() <= 1000
        && data.description is string && data.description.size() <= 5000
        && data.category is string && data.category.size() <= 100
        && data.stock is int && data.stock >= 0
        && (data.featured == null || data.featured is bool);
    }

    // --- Order Validation ---
    function isValidOrder(data) {
      return data.userId is string && data.userId.size() <= 128
        && data.customerName is string && data.customerName.size() <= 100
        && data.customerEmail is string && data.customerEmail.size() <= 100
        && data.customerPhone is string && data.customerPhone.size() <= 30
        && data.customerAddress is string && data.customerAddress.size() <= 500
        && data.items is list && data.items.size() > 0
        && data.totalAmount is number && data.totalAmount >= 0
        && data.paymentStatus is string && data.paymentStatus.size() <= 30
        && data.orderStatus is string && data.orderStatus.size() <= 30;
    }

    // --- User Validation ---
    function isValidUser(data) {
      return data.uid is string && data.uid == request.auth.uid
        && data.email is string && data.email.size() <= 100
        && data.name is string && data.name.size() <= 100
        && data.isAdmin is bool;
    }

    // --- Collection Routes ---

    // 1. PRODUCTS
    match /products/{productId} {
      allow read: if true; // Public access
      
      allow create: if isAdmin() && isValidId(productId) && isValidProduct(incoming());
      
      allow update: if isAdmin() && isValidProduct(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasAny(['price', 'stock', 'name', 'description', 'category', 'image', 'featured'])
      );
      
      allow delete: if isAdmin();
    }

    // 2. ORDERS
    match /orders/{orderId} {
      // Get single order: Owner or Admin
      allow get: if isOwner(existing().userId) || isAdmin();
      
      // List query enforced securely
      allow list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      
      // Create order: Signed in user creating their own order
      allow create: if isSignedIn() && isValidId(orderId) && isValidOrder(incoming()) && incoming().userId == request.auth.uid;
      
      // Update order: Admin can update anything. Owner can only update payment status/session info on pending orders
      allow update: if (
        isAdmin() && isValidOrder(incoming())
      ) || (
        isSignedIn() && isOwner(existing().userId) && existing().paymentStatus == 'pending' && isValidOrder(incoming()) && (
          incoming().diff(existing()).affectedKeys().hasOnly(['paymentStatus', 'paymentSessionId', 'updatedAt'])
        )
      );

      allow delete: if isAdmin();
    }

    // 3. USERS
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      
      // Allow user creation on registration. Forbid non-admin from self-assigning isAdmin = true
      allow create: if isSignedIn() && isOwner(userId) && isValidUser(incoming()) && (
        incoming().isAdmin == false || request.auth.token.email == "mdshamimbdyt0@gmail.com"
      );
      
      // Update user details
      allow update: if (isOwner(userId) && isValidUser(incoming()) && incoming().isAdmin == existing().isAdmin) || isAdmin();
      
      allow delete: if isAdmin();
    }
  }
}
